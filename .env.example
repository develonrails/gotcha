# Required
SECRET_KEY_BASE=generate-with-bin-rails-secret
POSTGRES_PASSWORD=change-me

# Findbug host (used in DSN URLs shown to users)
FINDBUG_HOST=10.0.0.4

# Optional: HTTP basic auth for the web UI (leave empty to disable)
FINDBUG_USERNAME=
FINDBUG_PASSWORD=

# Optional: change the port (default 80)
PORT=80
