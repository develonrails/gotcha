<h1>New Alert Channel</h1>
<p class="page-description">Configure a new alert channel to receive error notifications.</p>

<div class="card" style="max-width: 560px;">
  <div class="card-content">
    <%= form_tag alerts_path, method: :post do %>
      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        <div class="form-group">
          <label>Channel Type</label>
          <%= select_tag "alert_channel[channel_type]", options_for_select([["Select a channel type...", ""], ["Email", "email"], ["Slack", "slack"], ["Discord", "discord"], ["Webhook", "webhook"]], @channel.channel_type), id: "channel_type_select", onchange: "toggleConfigFields(this.value)" %>
        </div>
        <div class="form-group">
          <label>Name</label>
          <input type="text" name="alert_channel[name]" value="<%= @channel.name %>" placeholder="e.g., Production Slack, Dev Team Email">
        </div>
        <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer;">
          <input type="hidden" name="alert_channel[enabled]" value="0">
          <span class="toggle"><input type="checkbox" name="alert_channel[enabled]" value="1" <%= "checked" if @channel.enabled? %>><span class="toggle-slider"></span></span>
          <span>Enable this channel</span>
        </label>
        <div class="separator"></div>

        <%= render "channel_config_fields", channel: @channel %>

        <div class="separator"></div>
        <div style="display: flex; gap: 0.75rem;">
          <button type="submit" class="btn btn-primary">Create Channel</button>
          <a href="<%= alerts_path %>" class="btn btn-ghost">Cancel</a>
        </div>
      </div>
    <% end %>
  </div>
</div>
